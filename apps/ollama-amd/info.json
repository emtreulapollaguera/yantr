{\n  "name": "Ollama AMD",\n  "logo": "QmdJujFNrnbZ8Z9SVzrZGoUEvcxg5TQqizNg51nUcwcp5Z",\n  "tags": [\n    "ai",\n    "backend",\n    "gaming",\n    "server",\n    "self-hosted",\n    "homelab",\n    "llm",\n    "machine-learning",\n    "gpu",\n    "amd"\n  ],\n  "ports": [\n    { "port": 11434, "protocol": "HTTP", "label": "API" }\n  ],\n  "short_description": "Run large language models locally on AMD GPUs - Llama, Mistral, CodeLlama, and hundreds more.",\n  "description": "Ollama AMD is optimized for running large language models on AMD GPUs using ROCm. It supports hundreds of models including Llama 2/3, Mistral, CodeLlama, Phi, and many more. GPU acceleration provides significantly faster inference compared to CPU-only execution. Just download a model and start chatting or integrate via API. It handles model downloading, memory management, and GPU optimization automatically via ROCm. Perfect for privacy-conscious AI enthusiasts with AMD GPUs who want to run their own AI without cloud dependencies.",\n  "usecases": [\n    "Run Llama 2, Mistral, or other open-source LLMs completely offline with AMD GPU acceleration.",\n    "Build AI-powered applications that use local models via REST API with fast inference on AMD hardware.",\n    "Experiment with different AI models on your AMD GPU without API costs.",\n    "Create a private AI assistant for coding, writing, or analysis with AMD GPU-accelerated performance."\n  ],\n  "website": "https://ollama.ai",\n  "dependencies": [],\n  "notes": [\n    "Requires AMD GPU with ROCm support",\n    "ROCm drivers required - install AMD GPU drivers with ROCm for GPU passthrough",\n    "Models downloaded on first use - expect several GB per model",\n    "API available at port 11434 for integration with other apps",\n    "Device access (/dev/kfd and /dev/dri) required for AMD GPU access",\n    "Significantly faster inference compared to CPU-only Ollama"\n  ]\n}